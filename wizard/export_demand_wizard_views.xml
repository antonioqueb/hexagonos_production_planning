<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_export_demand_wizard_form" model="ir.ui.view">
        <field name="name">planning.export.demand.wizard.form</field>
        <field name="model">planning.export.demand.wizard</field>
        <field name="arch" type="xml">
            <form string="Exportar a Excel">
                <group>
                    <field name="snapshot_id" invisible="1"/>
                    <field name="export_type"/>
                </group>
                <group invisible="not file_data">
                    <field name="file_data" filename="file_name" widget="binary"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <footer>
                    <button name="action_export" string="Exportar" type="object" class="oe_highlight"
                            invisible="file_data"/>
                    <button string="Cerrar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open export wizard from snapshot -->
    <record id="action_open_export_wizard" model="ir.actions.act_window">
        <field name="name">Exportar a Excel</field>
        <field name="res_model">planning.export.demand.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_snapshot_id': active_id}</field>
    </record>
</odoo>