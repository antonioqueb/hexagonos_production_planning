<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_generate_demand_wizard_form" model="ir.ui.view">
        <field name="name">planning.generate.demand.wizard.form</field>
        <field name="model">planning.generate.demand.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar Demanda">
                <group>
                    <field name="snapshot_id" invisible="1"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="warehouse_ids" widget="many2many_tags"/>
                    <field name="partner_ids" widget="many2many_tags"/>
                    <field name="include_done"/>
                </group>
                <footer>
                    <button name="action_generate" string="Generar" type="object" class="oe_highlight"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
