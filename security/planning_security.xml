<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_planning" model="ir.module.category">
        <field name="name">Planificación de Producción</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_planning_user" model="res.groups">
        <field name="name">Usuario de Planificación</field>
        <field name="category_id" ref="module_category_planning"/>
    </record>

    <record id="group_planning_manager" model="res.groups">
        <field name="name">Responsable de Planificación</field>
        <field name="category_id" ref="module_category_planning"/>
        <field name="implied_ids" eval="[(4, ref('group_planning_user'))]"/>
    </record>
</odoo>
